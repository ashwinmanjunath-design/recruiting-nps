# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# cp env.template .env

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/candidate_360_nps"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Email mode: "local" for MailHog (dev), "production" for Resend (prod)
EMAIL_MODE="local"

# TEST EMAIL OVERRIDE (Development Only)
# In development (NODE_ENV !== "production"), ALL survey emails will be sent to this address
# regardless of the recipients selected in the UI.
# Leave empty or unset in production.
EMAIL_DEFAULT_TEST="ashwin.manjunath@omio.com"

# Resend API Key (required for production email sending)
RESEND_API_KEY=""

# MailHog Configuration (for local development)
MAILHOG_HOST="localhost"
MAILHOG_PORT="1025"

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL="http://localhost:5173"

# ============================================
# NODE ENVIRONMENT
# ============================================
# Set to "development" for local dev, "production" for production
NODE_ENV="development"

# ============================================
# SMARTRECRUITERS INTEGRATION (Optional)
# ============================================
SMARTRECRUITERS_API_KEY=""
SMARTRECRUITERS_API_URL="https://api.smartrecruiters.com"

# ============================================
# NOTES
# ============================================
# - EMAIL_DEFAULT_TEST: All emails in development will go to this address
# - NODE_ENV: Must be "development" for email override to work
# - In production, set NODE_ENV="production" and EMAIL_DEFAULT_TEST will be ignored

